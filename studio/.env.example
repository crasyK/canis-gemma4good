# Copy to .env.local (gitignored). Never commit filled values.
# The public demo at https://canis.appwrite.network is built with CI/host secrets, not this repo.

VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_project_id
VITE_APPWRITE_DATABASE_ID=your_database_id
VITE_APPWRITE_BUCKET_MATERIALS=materials

VITE_CANISCLI_URL=http://localhost:5000

SKIP_PREFLIGHT_CHECK=true
